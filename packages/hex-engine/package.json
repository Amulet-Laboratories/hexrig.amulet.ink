{
  "name": "@amulet-laboratories/hex-engine",
  "version": "1.0.0",
  "description": "Generative design token engine — OKLCH color generation, typography, spacing, and motion for the Amulet ecosystem.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "design-tokens",
    "oklch",
    "generative",
    "themes",
    "hex-engine"
  ],
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/hexrig.amulet.ink"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
