{
  "name": "@amulet-laboratories/hex",
  "version": "0.2.0",
  "description": "Five-theme design token system — VSCode extension + web tokens (CSS custom properties + TypeScript).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./themes/*.css": "./dist/themes/*.css",
    "./themes/*": {
      "types": "./dist/themes/*.d.ts",
      "import": "./dist/themes/*.js",
      "require": "./dist/themes/*.cjs"
    }
  },
  "files": [
    "dist",
    "themes"
  ],
  "scripts": {
    "build": "tsup && pnpm build:css && pnpm build:vscode",
    "build:css": "tsx src/build/generate-css.ts",
    "build:vscode": "tsx src/build/generate-vscode-themes.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/build/validate-all.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "design-tokens",
    "themes",
    "css-custom-properties",
    "vscode-theme",
    "hex"
  ],
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/amulet-laboratories/hexrig.amulet.ink"
  }
}
