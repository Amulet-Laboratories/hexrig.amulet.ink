{
  "name": "@amulet-laboratories/hex",
  "version": "3.0.0",
  "description": "Hex design token system — DOM integration, CSS custom properties, and Tailwind preset for the Amulet ecosystem.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@amulet-laboratories/hex-engine": "workspace:*",
    "@types/node": "^25.3.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "design-tokens",
    "themes",
    "oklch",
    "css-custom-properties",
    "hex"
  ],
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/hexrig.amulet.ink"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
