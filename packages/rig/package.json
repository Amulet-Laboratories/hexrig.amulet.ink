{
  "name": "@amulet-laboratories/rig",
  "version": "1.0.0",
  "description": "Minimal Vue 3 component library consuming Hex theme tokens via Tailwind CSS.",
  "type": "module",
  "main": "./dist/rig.cjs",
  "module": "./dist/rig.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rig.js",
      "require": "./dist/rig.cjs"
    },
    "./style.css": "./dist/rig.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@amulet-laboratories/hex": "workspace:*",
    "@iconify/vue": "^5.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "@amulet-laboratories/hex": ">=1.0.0",
    "@iconify/vue": "^5.0.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "vue",
    "components",
    "design-system",
    "tailwind",
    "hex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/hexrig.amulet.ink"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
