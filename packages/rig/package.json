{
  "name": "@amulet-laboratories/rig",
  "version": "0.1.0",
  "description": "Minimal Vue 3 component library consuming Hex theme tokens via Tailwind CSS.",
  "type": "module",
  "main": "./dist/rig.cjs",
  "module": "./dist/rig.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rig.js",
      "require": "./dist/rig.cjs"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./composables/*": {
      "types": "./dist/composables/*.d.ts",
      "import": "./dist/composables/*.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@amulet-laboratories/hex": "workspace:*",
    "@iconify/vue": "^5.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "vue",
    "components",
    "design-system",
    "tailwind",
    "hex"
  ],
  "license": "MIT"
}
