    "terminal.ansiBrightWhite": "#f0e8d8"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a6c58",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#c44030"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#c8a840"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8a9a68"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#c08060"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#d44a38"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#c44030"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7a6c58"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.other.inherited-class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#6888b0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c0b098"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#c08060"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#d44a38"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#6888b0"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value",
        "meta.property-value"
      ],
      "settings": {
        "foreground": "#8a9a68"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#c44030"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#c44030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#d44a38"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#8a9a68"
      }
    }
  ],
  "semanticHighlighting": true
}