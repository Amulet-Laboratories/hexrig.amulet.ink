    "terminal.ansiBrightYellow": "#b08828",
    "terminal.ansiBrightBlue": "#4078a8",
    "terminal.ansiBrightMagenta": "#9860a0",
    "terminal.ansiBrightCyan": "#18a0a8",
    "terminal.ansiBrightWhite": "#ffffff"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7a7a7a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.operator.logical", "keyword.operator.new"],
      "settings": {
        "foreground": "#9a4020"
      }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier", "entity.name.tag"],
      "settings": {
        "foreground": "#8a7020"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#3a6838"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#905060"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#506048"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic"],
      "settings": {
        "foreground": "#506048"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7a7a7a"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.other.inherited-class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#5a6a50"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#444444"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#905060"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#506048"
      }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name"],
      "settings": {
        "foreground": "#5a6a50"
      }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value", "meta.property-value"],
      "settings": {
        "foreground": "#3a6838"
      }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#9a4020"
      }
    },
    {
      "name": "Markdown heading",
      "scope": ["heading.1.markdown", "heading.2.markdown", "heading.3.markdown"],
      "settings": {
        "foreground": "#9a4020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#506048"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#3a6838"
      }
    }
  ],
  "semanticHighlighting": true
}
