  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a6058",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.logical",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#a83010"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#806008"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#3a6828"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#884030"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#90280c"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#a83010"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7a6058"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.other.inherited-class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#2a5880"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#442820"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#884030"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#90280c"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#2a5880"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value",
        "meta.property-value"
      ],
      "settings": {
        "foreground": "#3a6828"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#a83010"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown"
      ],
      "settings": {
        "foreground": "#a83010",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#90280c"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#3a6828"
      }
    }
  ],
  "semanticHighlighting": true
}