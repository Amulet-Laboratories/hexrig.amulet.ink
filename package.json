{
  "name": "@amulet-laboratories/hexrig",
  "private": true,
  "type": "module",
  "description": "Hex design token system + Rig component library — a Gesamtkunstwerk for the web.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amulet-Laboratories/hexrig.amulet.ink"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:deploy": "pnpm --filter hex build && pnpm --filter hex-origins build && pnpm --filter rig build && pnpm --filter site build && pnpm exec storybook build -o storybook-static && cp -r storybook-static packages/site/dist/storybook",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "pnpm -r typecheck",
    "clean": "rm -rf storybook-static node_modules packages/*/dist packages/*/.vite packages/*/node_modules",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@iconify/json": "^2.2.443",
    "@storybook/addon-a11y": "^8",
    "@storybook/addon-essentials": "^8",
    "@storybook/addon-links": "^8",
    "@storybook/blocks": "^8",
    "@storybook/vue3": "^8",
    "@storybook/vue3-vite": "^8",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "storybook": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<9.0.6": ">=9.0.6"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.30"
  },
  "packageManager": "pnpm@10.30.2"
}
