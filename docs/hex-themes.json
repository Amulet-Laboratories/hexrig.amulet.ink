  "_schema": {
    "version": "2.0.0",
    "name": "Hex",
    "description": "Five themes, five places. A journey from hearth to cove.",
    "arc": "Hearth (creation) \u2192 Abyss (void) \u2192 Hollow (growth) \u2192 Keep (construction) \u2192 Cove (shelter)",
    "tokenGuide": {
      "surfaces.base": "Page/app background. The default canvas.",
      "surfaces.raised": "Cards, modals, elevated containers.",
      "surfaces.elevated": "Nested elevated elements \u2014 dropdowns inside cards, stacked modals.",
      "surfaces.sunken": "Inset areas, code blocks, recessed panels.",
      "surfaces.overlay": "Overlay/dialog backdrop surface.",
      "text.primary": "Body text, headings, primary content.",
      "text.secondary": "Supporting text, descriptions, subtitles.",
      "text.muted": "Captions, metadata, disabled text. Min 3:1 on base (large text).",
      "text.inverse": "Text on dark surfaces within light themes (or vice versa). Use for badges, tags on inverted backgrounds.",
      "text.link": "Interactive text links. Always pair with underline for a11y.",
      "text.onAccent": "Text placed directly on accent-colored backgrounds.",
      "accents.primary": "Primary interactive color \u2014 buttons, active states, key UI elements.",
      "accents.secondary": "Secondary variant \u2014 less prominent interactive elements.",
      "accents.hover": "Hover state for accent elements. Always perceptibly different from primary.",
      "accents.active": "Active/pressed state. Always darker than primary.",
      "accents.muted": "Subtle accent background \u2014 tags, badges, tinted containers. Solid color, not rgba.",
      "status.*": "Semantic status colors. Independent from accents \u2014 success always looks like success across themes.",
      "focus.ring": "Outer glow for focus indicators. Use WITH focus.outline, not alone.",
      "focus.outline": "Solid 2px focus ring color. The primary a11y focus indicator.",
      "borders.*": "default for most borders, subtle for dividers, strong for emphasis.",
      "syntax.*": "Code editor syntax highlighting tokens.",
      "terminal.*": "ANSI terminal color mappings."
    }
  },
