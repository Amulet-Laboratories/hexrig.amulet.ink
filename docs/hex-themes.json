        ],
        "italic": true,
        "rationale": "A revival of Alternate Gothic No. 1 \u2014 tall, condensed, and imposing. It compresses language into tight vertical columns, like data streaming through a narrow channel. The Void speaks in headlines that feel like transmissions."
      },
      "body": {
        "family": "Inter",
        "source": "Google Fonts",
        "license": "SIL OFL 1.1",
        "weights": [
          300,
          400,
          500,
          600,
          700,
          800
        ],
        "italic": true,
        "rationale": "Designed by Rasmus Andersson specifically for computer interfaces. Optical sizing, tabular figures, and a vast weight range make it the most technically refined sans-serif available. Cold, precise, functional \u2014 the Void demands clarity above all."
      },
      "sans": {
        "family": "Space Grotesk",
        "source": "Google Fonts",
        "license": "SIL OFL 1.1",
        "weights": [
          300,
          400,
          500,
          600,
          700
        ],
        "italic": false,
        "rationale": "Derived from Space Mono with proportional spacing. Angular, geometric, slightly alien. Where Inter is the instrument panel, Space Grotesk is the mission patch \u2014 technical but with a signature."
      },
      "mono": {
        "family": "Monaspace Neon",
        "source": "GitHub (github.com/githubnext/monaspace)",
        "license": "SIL OFL 1.1",
        "weights": [
          300,
          400,
          500,
          600,
          700,
          800
        ],
        "italic": true,
        "rationale": "From GitHub's Monaspace superfamily \u2014 five metrically compatible monospace faces. Neon is the sans-serif variant with texture healing that optically adjusts spacing. The most technically advanced free monospace available. Sci-fi engineering in a font."
      }
    }
